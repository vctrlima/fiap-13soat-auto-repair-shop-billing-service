# Server
SERVER_PORT=3003
SERVER_HOST=http://localhost:3003

# AWS
AWS_REGION=us-east-2
AWS_ENDPOINT_URL=http://localhost:4566

# SNS / SQS
SNS_PAYMENT_EVENTS_TOPIC_ARN=arn:aws:sns:us-east-2:000000000000:payment-events
SQS_BILLING_WORK_ORDER_QUEUE_URL=http://localhost:4566/000000000000/billing-work-order-queue

# DynamoDB
DYNAMODB_INVOICES_TABLE=Invoices
DYNAMODB_PAYMENTS_TABLE=Payments

# Mercado Pago (optional — omit to use internal payment processing)
MERCADO_PAGO_ACCESS_TOKEN=

# CORS (optional — defaults to '*')
CORS_ORIGIN=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
